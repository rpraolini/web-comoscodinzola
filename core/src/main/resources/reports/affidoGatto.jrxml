	<parameter name="id" class="java.lang.String"/>
	<parameter name="idIter" class="java.lang.String"/>
	<parameter name="logo_url" class="java.lang.String"/>
	<parameter name="rag_sociale" class="java.lang.String"/>
	<parameter name="iscrizione" class="java.lang.String"/>
	<queryString language="SQL">
		<![CDATA[SELECT
  v.nome,
  v.eta,
  v.etaS,
  v.num_microchip,
  v.peso,
  v.taglia,
  v.descr_colore,
  v.sesso,
  IfNull(Concat(IfNull(v.tipo_razza, ""), " ", v.razza),"METICCIO") razza,
  v.id_animale,
  i.id_tipo_iter,
  Concat(c.cognome, " ", c.nome) AS affidante,
  v.caratteristiche,
  v.sterilizzato,
  Concat(a.cognome, " ", a.nome) AS adottante,
  a.regione,
  case when  p.sigla_automobilistica is not null then 
  Concat(a.comune, " (", p.sigla_automobilistica, ")")
  else a.comune end residenza,
  a.indirizzo,
  a.email,
  Concat(IfNull(a.telefono_1, ""), " ", IfNull(a.telefono_2, ""), " ", IfNull(a.cellulare, "")) AS telefono,
  a.nato_a,
  Date_Format(IfNull(a.data_nascita, ''), '%d/%m/%Y') AS data_nascita,
  a.cod_fiscale,
  td.documento,
  a.num_documento,
  v.id_tipo_animale
FROM
  v_animali v
  LEFT JOIN an_r_iter i ON i.id_animale = v.id_animale
  LEFT JOIN an_contatti c ON c.id_contatto = i.id_contatto_vol
  LEFT JOIN an_contatti a ON i.id_contatto_adottante = a.id_contatto
  LEFT JOIN an_x_province p ON p.id = a.id_provincia
  LEFT JOIN an_x_tipo_documento td ON a.id_tipo_documento = td.id_tipo_documento
WHERE
  v.id_animale = $P{id} AND
  i.id_tipo_iter = 2 and id_iter =  $P{idIter}]]>
	</queryString>

<!-- Created with Jaspersoft Studio version 6.5.1.final utlizzo versione della libreria JasperReports6.5.1  -->
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="volantino" pageWidth="842" pageHeight="595" orientation="Landscape" columnWidth="802" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" whenResourceMissingType="Error" uuid="d916c447-6dcf-4a5c-81e5-3d09ccd0f2eb">
	<property name="com.jaspersoft.studio.data.sql.tables" value=""/>
	<property name="com.jaspersoft.studio.data.defaultdataadapter" value="mysql-asso"/>
	<parameter name="id" class="java.lang.String"/>
	<parameter name="path_url" class="java.lang.String"/>
	<parameter name="logo_url" class="java.lang.String"/>
	<parameter name="qrcode_url" class="java.lang.String"/>
	<parameter name="sito" class="java.lang.String"/>
	<queryString language="SQL">
		<![CDATA[SELECT
  v.nome,
  Replace(Replace(v.etaS, "a", "anni"), "m", "mesi") etaS,
  Lower(v.taglia) taglia,
  v.descr_colore,
  CASE
    WHEN v.sesso = 'M'
    THEN "maschio"
    ELSE "femmina"
  END sesso,
  Concat(Lower(v.tipo_razza), "  ", Lower(v.razza)) razza,
  Concat(v.id_animale, "/", f.nome_file) url,
  c.provincia localita,
  CASE
    WHEN v.eta = 'CUCCIOLO'
    THEN Concat("da grande peserò circa ", v.peso, " Kg.")
    ELSE Concat("peso ", v.peso, " Kg.")
  END peso,
 ifnull((select Concat(" e ",x.note) from an_r_caratteri x where x.id_animale = v.id_animale and (x.id_carattere = 0 or x.id_carattere is null)),"") note,
 CASE WHEN c.provincia = 'Benevento' THEN 'nel centro nord.' ELSE 'anche nelle province limitrofe.' END luogo
FROM
  v_animali v
  INNER JOIN an_foto f ON v.id_animale = f.id_animale
  INNER JOIN v_last_eventi_storici ve ON ve.id_animale = v.id_animale
  INNER JOIN an_contatti c ON c.id_contatto = ve.id_contatto
WHERE
  f.id_tipo_foto = 1 AND
  f.pubblica = 1 AND
  v.id_animale =  $P{id}]]>
	</queryString>

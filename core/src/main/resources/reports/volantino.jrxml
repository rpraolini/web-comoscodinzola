				</textElement>
				<textFieldExpression><![CDATA[IF($F{peso} == null,CONCATENATE("Ho ",$F{etaS}," e  mi trovo in provincia di ",$F{localita}," ma cerco casa ", $F{luogo}, "\nSono ",$F{sesso},$F{note},". Ho tutti i vaccini e il microchip. Chiama per me!"),CONCATENATE("Ho ",$F{etaS}," e  ",$F{peso}," Mi trovo in provincia di ",$F{localita}," ma cerco casa ", $F{luogo}, "\nSono ",$F{sesso},$F{note},". Ho tutti i vaccini e il microchip. Chiama per me!"))]]></textFieldExpression>

	<queryString language="SQL">
		<![CDATA[SELECT
				  concat(c.nome," ",c.cognome) as volontaria,
				  i.nome as nome_adottante,
				  i.quest_key,
				  a.nome as nome_animale, c.cellulare
				FROM
				  an_r_iter i
				  INNER JOIN an_contatti c ON i.id_contatto_vol = c.id_contatto
				  INNER JOIN an_animale a ON i.id_animale = a.id_animale
				WHERE
				  i.quest_key = $P{key}]]>
	</queryString>

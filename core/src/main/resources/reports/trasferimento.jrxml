<!-- Created with Jaspersoft Studio version 6.16.0.final utlizzo versione della libreria JasperReports6.16.0-48579d909b7943b64690c65c71e07e0b80981928  -->
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="trasferimento" pageWidth="595" pageHeight="842" columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="438693be-d045-4cc1-8000-4cd615858955">
	<property name="com.jaspersoft.studio.data.sql.tables" value=""/>
	<property name="com.jaspersoft.studio.data.defaultdataadapter" value="mysql-asso"/>
	<parameter name="id" class="java.lang.String"/>
	<parameter name="url_stemma" class="java.lang.String"/>
	<queryString language="SQL">
		<![CDATA[Select
    v.nome,
    v.etaS,
    v.dt_nascita,
    v.num_microchip,
    v.peso,
    v.taglia,
    v.descr_colore,
    v.sesso,
    IfNull(Concat(IfNull(v.tipo_razza, ""), " ", v.razza), "METICCIO") razza,
    v.id_animale,
    i.id_tipo_iter,
    v.caratteristiche,
    v.sterilizzato,
    Concat(p_c.cognome, " ", p_c.nome) As proprietario,
    p_c.regione As p_regione,
    Concat(p_c.comune, " (", p_p.sigla_automobilistica, ")") p_residenza,
    p_c.indirizzo As p_indirizzo,
    p_c.email As p_email,
    Concat(IfNull(p_c.telefono_1, ""), " ", IfNull(p_c.telefono_2, ""), " ", IfNull(p_c.cellulare, "")) As p_telefono,
    p_c.nato_a As p_nato_a,
    Date_Format(IfNull(p_c.data_nascita, ''), '%d/%m/%Y') As p_data_nascita,
    p_c.cod_fiscale As p_cod_fiscale,
    p_c.num_documento As p_num_documento,
    p_d.documento As p_documento,
    Concat(ad.cognome, " ", ad.nome) As adottante,
    ad.regione As ad_regione,
    Concat(ad.comune, " (", ad_p.sigla_automobilistica, ")") ad_residenza,
    ad.indirizzo As ad_indirizzo,
    ad.email As ad_email,
    Concat(IfNull(ad.telefono_1, ""), " ", IfNull(ad.telefono_2, ""), " ", IfNull(ad.cellulare, "")) As ad_telefono,
    ad.nato_a As ad_nato_a,
    Date_Format(IfNull(ad.data_nascita, ''), '%d/%m/%Y') As ad_data_nascita,
    ad.cod_fiscale As ad_cod_fiscale,
    ad.num_documento As ad_num_documento,
    ad_d.documento As ad_documento,
    v.descr_tipo_animale,
    i.id_pratica,
    st.macro_stato
From
    v_animali v Left Join
    an_r_iter i On i.id_animale = v.id_animale Left Join
    an_contatti ad On i.id_contatto_adottante = ad.id_contatto Left Join
    an_x_province ad_p On ad_p.id = ad.id_provincia Left Join
    an_x_tipo_documento ad_d On ad_d.id_tipo_documento = ad.id_tipo_documento Left Join
    v_animali_proprietario p_c On p_c.id_animale = v.id_animale Left Join
    an_x_tipo_documento p_d On p_d.id_tipo_documento = p_c.id_tipo_documento Left Join
    an_x_province p_p On p_p.id = p_c.id_provincia Left Join
    as_pratiche pr On i.id_pratica = pr.id_pratica Inner Join
    as_x_stati st On pr.id_stato = st.id_stato_p
Where
    v.id_animale = $P{id} And
    i.id_tipo_iter = 4 and
    st.macro_stato = 'ATTIVO'
]]>
	</queryString>

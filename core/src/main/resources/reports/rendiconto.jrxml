<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="rendiconto" pageWidth="595" pageHeight="842" columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="ad5a5465-5153-4911-a631-598266a51c0e">
	<property name="com.jaspersoft.studio.data.sql.tables" value=""/>
	<property name="com.jaspersoft.studio.data.defaultdataadapter" value="mysql-asso"/>
	<parameter name="anno" class="java.lang.String"/>
	<queryString language="SQL">
		<![CDATA[Select
    Sum(md.importo) As totImporto,
    s.descrizione sezione,
    ss.descrizione sotto_sezione,
    v.descrizione voce,
    sv.descrizione sottovoce,
    s.id_sezione,
    ss.tipo_sotto_sezione tipo_sotto_sezione,
    ss.id_sotto_sezione,
    v.id_cr_voce,
    sv.id_cr_sottovoce
From
    org_movimenti_dettaglio md Right Join
    org_rnd_cr_sottovoci sv On md.id_cr_sottovoce = sv.id_cr_sottovoce Right Join
    org_rnd_cr_voci v On sv.id_cr_voce = v.id_cr_voce Right Join
    org_rnd_sotto_sezioni ss On v.id_sotto_sezione = ss.id_sotto_sezione Right Join
    org_rnd_sezioni s On ss.id_sezione = s.id_sezione Left Join
    org_movimenti m On md.id_movimento = m.id_movimento
Where
    (Year(m.dt_operazione) Is Null Or
        Year(m.dt_operazione) = $P{anno}) and s.id_sezione = 'A'
Group By
    s.descrizione,
    ss.descrizione,
    v.descrizione,
    sv.descrizione,
    s.id_sezione,
    ss.tipo_sotto_sezione,
    ss.id_sotto_sezione,
    v.id_cr_voce,
    sv.id_cr_sottovoce
Order By
    s.id_sezione,
    ss.tipo_sotto_sezione,
    ss.id_sotto_sezione,
    v.id_cr_voce,
    sv.id_cr_sottovoce]]>
	</queryString>

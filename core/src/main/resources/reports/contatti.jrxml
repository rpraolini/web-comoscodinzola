	<subDataset name="tableDataset" uuid="2955f8df-9a72-47f1-8043-01e9e50d9131">
		<property name="com.jaspersoft.studio.data.defaultdataadapter" value="mysql-asso"/>
		<queryString language="SQL">
			<![CDATA[SELECT
  t.tipo_contatto,
  a.nome,
  a.cognome,
  a.nato_a,
  a.data_nascita,
  a.cod_fiscale,
  a.rag_sociale,
  a.regione,
  a.provincia,
  a.comune,
  a.indirizzo,
  a.email,
  a.telefono_1,
  a.telefono_2,
  a.cellulare,
  a.blacklist
FROM
  an_contatti a
  INNER JOIN an_x_tipo_contatto t ON a.id_tipo_contatto = t.id_tipo_contatto
ORDER BY
  t.tipo_contatto,
  a.cognome,
  a.rag_sociale]]>
		</queryString>

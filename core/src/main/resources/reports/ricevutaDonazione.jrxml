		<property name="com.jaspersoft.studio.field.tree.path" value="org_anagrafica"/>
	</field>
	<field name="email" class="java.lang.String">
		<property name="com.jaspersoft.studio.field.label" value="email"/>
		<property name="com.jaspersoft.studio.field.tree.path" value="org_anagrafica"/>
	</field>
	<field name="url" class="java.lang.String">
		<property name="com.jaspersoft.studio.field.label" value="url"/>
		<property name="com.jaspersoft.studio.field.tree.path" value="org_anagrafica"/>
	</field>
	<field name="importo" class="java.math.BigDecimal">
		<property name="com.jaspersoft.studio.field.label" value="importo"/>
		<property name="com.jaspersoft.studio.field.tree.path" value="org_movimenti"/>
	</field>
	<field name="nome" class="java.lang.String">
		<property name="com.jaspersoft.studio.field.label" value="nome"/>
		<property name="com.jaspersoft.studio.field.tree.path" value="an_contatti"/>

		<property name="com.jaspersoft.studio.field.tree.path" value="an_contatti"/>
	</field>
	<field name="cod_fiscale" class="java.lang.String">
		<property name="com.jaspersoft.studio.field.label" value="cod_fiscale"/>
		<property name="com.jaspersoft.studio.field.tree.path" value="an_contatti"/>
	</field>
	<field name="id_movimento" class="java.lang.Integer">
		<property name="com.jaspersoft.studio.field.label" value="id_movimento"/>

			<property name="com.jaspersoft.studio.field.label" value="descrizione"/>
			<property name="com.jaspersoft.studio.field.tree.path" value="rc_x_merceologia"/>
		</field>
		<field name="tipo_merce" class="java.lang.String">
			<property name="com.jaspersoft.studio.field.label" value="tipo_merce"/>
			<property name="com.jaspersoft.studio.field.tree.path" value="rc_x_merceologia"/>
		</field>
		<field name="descr_tipo_animale" class="java.lang.String">
			<property name="com.jaspersoft.studio.field.label" value="descr_tipo_animale"/>
			<property name="com.jaspersoft.studio.field.tree.path" value="an_x_tipo_animale"/>
		</field>
		<field name="quantita" class="java.lang.Integer">
			<property name="com.jaspersoft.studio.field.label" value="quantita"/>
			<property name="com.jaspersoft.studio.field.tree.path" value="rc_r_evento_merce"/>
		</field>
		<field name="peso" class="java.math.BigDecimal">
			<property name="com.jaspersoft.studio.field.label" value="peso"/>
			<property name="com.jaspersoft.studio.field.tree.path" value="rc_r_evento_merce"/>
		</field>
	</subDataset>
	<parameter name="id" class="java.lang.String"/>
	<queryString language="SQL">
		<![CDATA[SELECT
  a.id_evento,
  a.dt_evento,
  b.rag_sociale,
  b.indirizzo,
  b.comune,
  b.provincia,
  b.orario_apertura
FROM
  rc_evento a
  INNER JOIN an_contatti b ON a.id_punto_raccolta = b.id_contatto
  WHERE a.id_evento = $P{id}]]>
	</queryString>

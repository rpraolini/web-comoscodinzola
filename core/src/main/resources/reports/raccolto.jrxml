	<subDataset name="raccolto" uuid="444f9dd1-8557-4ae6-b702-eed076f241a5">
		<property name="com.jaspersoft.studio.data.sql.tables" value=""/>
		<property name="com.jaspersoft.studio.data.defaultdataadapter" value="mysql-asso"/>
		<parameter name="id_e" class="java.lang.String"/>
		<queryString language="SQL">
			<![CDATA[SELECT
  a.id_evento,
  b.descrizione,
  b.tipo_merce,
  c.descr_tipo_animale,
  a.quantita,
  a.peso
FROM
  rc_r_evento_merce a
  INNER JOIN rc_x_merceologia b ON a.id_merce = b.id_merce
  INNER JOIN an_x_tipo_animale c ON b.id_tipo_animale = c.id_tipo_animale
WHERE
  a.id_evento =  $P{id_e}
ORDER BY
  b.descrizione]]>
		</queryString>
		<field name="id_evento" class="java.lang.Integer">
			<property name="com.jaspersoft.studio.field.label" value="id_evento"/>
			<property name="com.jaspersoft.studio.field.tree.path" value="rc_r_evento_merce"/>
		</field>

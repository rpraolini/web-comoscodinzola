	<parameter name="key_s" class="java.lang.String"/>
	<queryString language="SQL">
		<![CDATA[SELECT
				  s.sezione,
				  d.domanda,
				  q.risposta,
				  q.ordine,
				  i.quest_key
				FROM
				  an_r_questionari q
				  INNER JOIN an_x_quest_domande d ON q.id_domanda = d.id_domanda
				  INNER JOIN an_x_quest_sezioni s ON q.id_sezione = s.id_sezione
				  INNER JOIN an_r_iter i ON q.id_richiesta = i.id_iter
				WHERE
				  i.quest_key = $P{key_s}
				ORDER BY
				  s.id_sezione, q.ordine]]>
	</queryString>
